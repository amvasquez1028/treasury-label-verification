# ASP.NET Core
ASPNETCORE_URLS=http://0.0.0.0:8080
ASPNETCORE_ENVIRONMENT=Production

# OCR concurrency
OCR_MAX_PARALLEL=2
OCR_MAX_PER_USER=1
MAX_UPLOAD_BYTES=5242880

# Auth / registration
DISABLE_PUBLIC_REGISTRATION=true
SEED_DEMO_USERS=false
# Set locally only — never commit production demo passwords
DEMO_AGENT_PASSWORD=
DEMO_PARALLEL_PASSWORD=
AUTH_DB_PATH=/data/auth.db
ConnectionStrings__Auth=Data Source=/data/auth.db

# OCR paths (container layout)
Ocr__TessDataPath=/app/tessdata
Ocr__TimeoutSeconds=5
Ocr__MaxParallel=2

# SendGrid (registration approval emails)
SendGrid__ApiKey=
SendGrid__FromEmail=noreply@your-domain.gov
SendGrid__FromName=Treasury Label Verification
SendGrid__ApproverEmail=admin@your-domain.gov
SendGrid__PublicBaseUrl=https://your-app.azurewebsites.net

# Contact form notifications
CONTACT_NOTIFY_EMAIL=placeholder
Contact__NotifyEmail=placeholder

