{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Auth": "Data Source=auth.db"
  },
  "Cola": {
    "ColasDir": "testdata/colas"
  },
  "Ocr": {
    "TessDataPath": "tessdata",
    "TimeoutSeconds": 8,
    "MaxParallel": 6,
    "FlatArtworkMaxOcrSide": 1200,
    "FlatArtworkEnginePoolSize": 6,
    "SubmissionGradeTargetMs": 4000,
    "PerLabelWallClockMs": 6000,
    "UseFieldBandTargetedOcr": true
  },
  "Verification": {
    "AbvTolerance": 0.1,
    "BrandMatchThreshold": 0.75
  },
  "Readability": {
    "MinAlphanumericCharacters": 25,
    "MinSubstantiveWords": 4,
    "MinBlurVariance": 40.0,
    "MinContrastStdDev": 12.0,
    "FlatArtworkMinAlphanumericCharacters": 40,
    "FlatArtworkMinSubstantiveWords": 8,
    "FlatArtworkMinBlurVariance": 8.0
  },
  "FlatLabelCompliance": {
    "MinWarningContrastRatio": 3.5,
    "MinLabelContrastRatio": 3.0,
    "MinBoldTypographyConfidence": 0.55,
    "MinFooterInkDensity": 0.04,
    "WarningPlacementBottomMargin": 0.01
  },
  "Layout": {
    "AnnotationsDir": "testdata/layout-annotations",
    "ModelPath": "testdata/layout-models/label-layout-v1.onnx",
    "PreferOnnx": false,
    "MinRegionConfidence": 0.55,
    "RoiOcrBudgetMs": 0,
    "EnableGuidedRoiOcr": false
  },
  "SendGrid": {
    "ApiKey": "",
    "FromEmail": "noreply@label-verify.demo",
    "FromName": "Treasury Label Verification",
    "ApproverEmail": "admin@label-verify.demo",
    "PublicBaseUrl": "http://localhost:8080"
  },
  "DISABLE_PUBLIC_REGISTRATION": false,
  "Auth": {
    "AllowGetApprovalAction": false,
    "ApprovalTokenTtlHours": 1
  }
}
